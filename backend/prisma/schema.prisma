generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Video {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  platform  String
  title     String
  thumbnail String
  views     Int
  likes     Int
  hashtags  String[]
  createdAt DateTime @default(now())
}
